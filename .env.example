# Copy to a private, uncommitted location and fill in your own values.
# Secrets belong in `wrangler secret` / Cloudflare Pages env / a local file the
# agent reads — NOT in the repository. Nothing here is a real credential.

# =========================================================================
# Home agent  (apps/host-agent)  — read from the process environment
# =========================================================================
MIRROR_DEVICE_ID=device_replace_me           # opaque device id (mint with scripts/)
MIRROR_SESSION_ID=session_replace_me         # bootstrap session id
MIRROR_DEVICE_TOKEN=replace_me               # HMAC device token (KEEP SECRET) — prod
# MIRROR_DEV_TICKET=replace_me               # local dev ticket (used if no device token)
MIRROR_WS_URL=wss://my-mirror-signaling.<your-subdomain>.workers.dev/ws
MIRROR_VIDEO_SOURCE=desktop                  # desktop (real capture) | synthetic (test)
MIRROR_VIDEO_PROFILE=balanced                # balanced (720p/15) | low (540p/10)
MIRROR_CONTROL_ENABLED=0                     # 1 = allow remote input injection
MIRROR_CLIPBOARD_ENABLED=0                   # 1 = send home-PC clipboard text
MIRROR_FILES_ENABLED=0                       # 1 = enable sandboxed file transfer
# MIRROR_FILES_DIR=C:\Users\you\MirrorShare  # sandbox root (default ~/MirrorShare)

# =========================================================================
# Signaling Worker  (apps/signaling)  — set with: wrangler secret put <NAME>
# =========================================================================
# SESSION_TICKET_SECRET   HMAC secret; MUST equal the Pages Function's value
# DEVICE_AUTH_SECRET      HMAC secret for verifying agent device tokens
# VIEWER_ORIGIN           allowed viewer origin, e.g. https://<project>.pages.dev
# TURN_KEY_ID             Cloudflare Realtime TURN key id     (optional)
# TURN_API_TOKEN          Cloudflare Realtime TURN API token  (optional)

# =========================================================================
# Viewer Pages Function  (apps/viewer)  — set in the Pages project env
# =========================================================================
# ACCESS_ISSUER           https://<your-team>.cloudflareaccess.com
# ACCESS_AUD              your Access application AUD tag
# ACCESS_ALLOWED_EMAILS   comma-separated allowlist
# SESSION_TICKET_SECRET   MUST equal the Worker's value
# MIRROR_DEVICE_ID        the device id the viewer targets

# =========================================================================
# Viewer build-time  (apps/viewer)  — passed to `vite build`
# =========================================================================
# VITE_SIGNALING_WS_URL=wss://my-mirror-signaling.<your-subdomain>.workers.dev/ws
